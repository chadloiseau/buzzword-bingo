{
  "name": "buzzword-bingo",
  "version": "1.0.0",
  "description": "Real-time multiplayer business buzzword bingo game",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:rules": "jest --testPathPattern=rules",
    "emulators": "firebase emulators:start --only database",
    "emulators:test": "firebase emulators:exec --only database 'npm test'"
  },
  "keywords": [
    "bingo",
    "firebase",
    "realtime",
    "multiplayer"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "index.html"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/"
    ]
  }
}
